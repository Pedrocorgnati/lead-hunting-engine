# ============================================
# VARIAVEIS DE AMBIENTE - LEAD HUNTING ENGINE
# ============================================
# Copie este arquivo para .env e preencha os valores
# Este arquivo é seguro para versionar (valores são placeholders)
# ============================================

# ────────────────────────────────────────────
# AMBIENTE
# ────────────────────────────────────────────
NODE_ENV=development

# ────────────────────────────────────────────
# APLICACAO
# ────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ────────────────────────────────────────────
# BANCO DE DADOS - PostgreSQL (Supabase)
# ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:6543/postgres

# ────────────────────────────────────────────
# SUPABASE (Backend-as-a-Service)
# ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui
SUPABASE_WEBHOOK_SECRET=sua-webhook-secret-aqui

# ────────────────────────────────────────────
# SEGURANCA
# ────────────────────────────────────────────
# Gere com: openssl rand -hex 32
ENCRYPTION_KEY=gere-com-openssl-rand-hex-32

# Gere com: openssl rand -base64 32
JWT_SECRET=gere-com-openssl-rand-base64-32

# ────────────────────────────────────────────
# AI / LLM
# ────────────────────────────────────────────
ANTHROPIC_API_KEY=sua-chave-anthropic-aqui
OPENAI_API_KEY=sk-proj-seu-id-aqui

# ────────────────────────────────────────────
# EMAIL
# ────────────────────────────────────────────
RESEND_API_KEY=re_seu-id-aqui

# ────────────────────────────────────────────
# TRIGGER.DEV (OPTIONAL)
# ────────────────────────────────────────────
TRIGGER_SECRET_KEY=seu-trigger-secret-aqui

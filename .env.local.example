# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Banco de dados — Supabase Pooler (porta 6543 para queries, Transaction mode)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection para migrations Prisma (porta 5432 — sem pooler)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# Criptografia — gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ou: openssl rand -hex 32
ENCRYPTION_KEY=                    # 64 chars hex (32 bytes) — OBRIGATÓRIO

# Aplicação
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Trigger.dev (necessário para módulos 10+)
TRIGGER_SECRET_KEY=

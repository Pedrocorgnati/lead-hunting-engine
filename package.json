{
  "name": "lead-hunting-engine",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "test": "jest --config jest.config.ts",
    "test:integration": "jest --config jest.integration.config.ts --runInBand",
    "test:integration:watch": "jest --config jest.integration.config.ts --watch",
    "test:all": "jest --config jest.config.ts && jest --config jest.integration.config.ts --runInBand",
    "seed:dev": "tsx prisma/seed/dev.ts",
    "seed:test": "tsx prisma/seed/test.ts",
    "seed:prod": "tsx prisma/seed/prod.ts",
    "docker:dev": "docker compose up",
    "docker:dev:build": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:clean": "docker compose down -v",
    "docker:prod:build": "docker build -t lead-hunting-engine:latest .",
    "setup": "./scripts/bootstrap.sh",
    "reset": "./scripts/bootstrap.sh --reset"
  },
  "prisma": {
    "seed": "tsx prisma/seed/dev.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@base-ui/react": "^1.3.0",

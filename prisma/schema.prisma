generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  ADMIN
  OPERATOR
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum CollectionJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  PAUSED
  PARTIAL
  CANCELLED
}

enum DataSource {
  GOOGLE_MAPS
  INSTAGRAM
  FACEBOOK
  WEBSITE
  YELP
  APONTADOR
  GUIA_MAIS
  LINKEDIN_COMPANY
  HERE_PLACES
  TOMTOM
  OUTSCRAPER
  APIFY
  SHOPEE
  MERCADOLIVRE
  OVERTURE_MAPS
}

enum EnrichmentStatus {
  PENDING
  COMPLETE
  PARTIAL
}

enum LeadStatus {
  NEW
  CONTACTED
  NEGOTIATING
  CONVERTED
  DISCARDED
  DISQUALIFIED
  FALSE_POSITIVE
  ENRICHMENT_PENDING
}

enum LeadTemperature {
  COLD
  WARM
  HOT
}

enum OpportunityType {
  A_NEEDS_SITE
  B_NEEDS_SYSTEM
  C_NEEDS_AUTOMATION
  D_NEEDS_ECOMMERCE
  E_SCALE
}

// TASK-2 intake-review (CL-310): landing — waitlist
enum WaitlistStatus {
  PENDING
  INVITED
  REJECTED
}

// TASK-2 intake-review (CL-311): landing — contact messages
enum ContactStatus {
  NEW
  READ
  REPLIED
  ARCHIVED
}

// TASK-2 intake-review (CL-307): segmentacao de landing leads
enum BusinessType {
  AGENCIA
  CONSULTORIA
  SDR
  FREELA
  OUTRO
}

// ─────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────

model UserProfile {
  id                  String    @id @db.Uuid
  email               String    @unique @db.VarChar(255)
  name                String?   @db.VarChar(255)
  role                UserRole  @default(OPERATOR)
  avatarUrl           String?   @map("avatar_url")
  termsAcceptedAt     DateTime? @map("terms_accepted_at")
  deletionRequestedAt     DateTime? @map("deletion_requested_at")
  onboardingCompletedAt   DateTime? @map("onboarding_completed_at")
  onboardingStep          Int       @default(0) @map("onboarding_step")
  onboardingData          Json?     @map("onboarding_data")
  leadsPerMonthMax        Int       @default(500) @map("leads_per_month_max")
  maxConcurrentJobs       Int       @default(3)   @map("max_concurrent_jobs")
  deactivatedAt           DateTime? @map("deactivated_at")
  mustResetPassword       Boolean   @default(false) @map("must_reset_password")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  invitesSent    Invite[]         @relation("InvitedBy")
  collectionJobs CollectionJob[]
  leads          Lead[]
  rawLeadData    RawLeadData[]
  pitchTemplates PitchTemplate[]
  auditLogs      AuditLog[]
  notifications  Notification[]
  notificationPrefs NotificationPreference[]
  pushSubscriptions PushSubscription[]

  @@map("user_profiles")
}

model Invite {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String       @db.VarChar(255)
  role        UserRole     @default(OPERATOR)
  status      InviteStatus @default(PENDING)
  token       String       @unique @db.VarChar(255)
  invitedById String?      @map("invited_by_id") @db.Uuid
  expiresAt   DateTime     @map("expires_at")
  acceptedAt  DateTime?    @map("accepted_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  invitedBy UserProfile? @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([email])
  @@index([status])
  @@index([invitedById])
  @@map("invites")
}

model CollectionJob {
  id              String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  name            String?             @db.VarChar(255)
  status          CollectionJobStatus @default(PENDING)
  city            String              @db.VarChar(255)
  state           String?             @db.VarChar(100)
  country         String              @default("BR") @db.VarChar(100)
  niche           String              @db.VarChar(255)
  sources         DataSource[]
  limitVal        Int?                @map("limit_val")
  totalEstimated  Int?                @map("total_estimated")
  processedLeads  Int                 @default(0) @map("processed_leads")
  resultCount     Int                 @default(0) @map("result_count")
  progress        Int                 @default(0)
  triggerId       String?             @map("trigger_id") @db.VarChar(255)
  errorMessage    String?             @map("error_message")
  currentSource   String?             @map("current_source") @db.VarChar(50)
  errorLog        Json?               @map("error_log")
  startedAt       DateTime?           @map("started_at")
  completedAt     DateTime?           @map("completed_at")
  retriedFromId   String?             @map("retried_from_id") @db.Uuid
  metadata        Json?
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  user        UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  rawLeadData RawLeadData[]
  leads       Lead[]

  @@index([userId, status])
  @@map("collection_jobs")
}

model RawLeadData {
  id                  String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  externalId          String?          @unique @map("external_id") @db.VarChar(500)
  jobId               String           @map("job_id") @db.Uuid
  userId              String           @map("user_id") @db.Uuid
  source              DataSource
  sourceUrl           String?          @map("source_url")
  collectedAt         DateTime         @default(now()) @map("collected_at")
  businessName        String?          @map("business_name") @db.VarChar(500)
  phone               String?          @db.VarChar(50)
  phoneNormalized     String?          @map("phone_normalized") @db.VarChar(20)
  address             String?
  city                String?          @db.VarChar(255)
  state               String?          @db.VarChar(100)
  lat                 Decimal?         @db.Decimal(9, 6)
  lng                 Decimal?         @db.Decimal(9, 6)
  website             String?
  email               String?          @db.VarChar(255)
  category            String?          @db.VarChar(255)
  rating              Decimal?         @db.Decimal(2, 1)
  reviewCount         Int?             @map("review_count")
  openNow             Boolean?         @map("open_now")
  priceLevel          Int?             @map("price_level")
  siteReachable       Boolean?         @map("site_reachable")
  siteHasSsl          Boolean?         @map("site_has_ssl")
  siteTitle           String?          @map("site_title") @db.VarChar(500)
  siteMobileFriendly  Boolean?         @map("site_mobile_friendly")
  instagramHandle        String?          @map("instagram_handle") @db.VarChar(255)
  instagramFollowers     Int?             @map("instagram_followers")
  instagramLastPostAt    DateTime?        @map("instagram_last_post_at")
  instagramPostFrequency Int?             @map("instagram_post_frequency")
  facebookUrl            String?          @map("facebook_url")
  facebookFollowers      Int?             @map("facebook_followers")
  facebookLastPostAt     DateTime?        @map("facebook_last_post_at")
  facebookEngagementRate Float?           @map("facebook_engagement_rate")
  openingHours        Json?            @map("opening_hours")
  rawJson             Json?            @map("raw_json")
  enrichmentStatus    EnrichmentStatus @default(PENDING) @map("enrichment_status")
  enrichmentData      Json?            @map("enrichment_data")
  leadId              String?          @map("lead_id") @db.Uuid
  retentionUntil      DateTime?        @map("retention_until")
  createdAt           DateTime         @default(now()) @map("created_at")
  updatedAt           DateTime         @updatedAt @map("updated_at")

  job  CollectionJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  user UserProfile   @relation(fields: [userId], references: [id], onDelete: Cascade)
  lead Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  dataProvenance DataProvenance[]

  @@index([jobId])
  @@index([phoneNormalized])
  @@index([userId])
  @@map("raw_lead_data")
}

model Lead {
  id                 String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String          @map("user_id") @db.Uuid
  jobId              String?         @map("job_id") @db.Uuid
  status             LeadStatus      @default(NEW)
  businessName       String          @map("business_name") @db.VarChar(500)
  phone              String?         @db.VarChar(50)
  phoneNormalized    String?         @map("phone_normalized") @db.VarChar(20)
  address            String?
  city               String?         @db.VarChar(255)
  state              String?         @db.VarChar(100)
  website            String?
  email              String?         @db.VarChar(255)
  category           String?         @db.VarChar(255)
  instagramHandle        String?         @map("instagram_handle") @db.VarChar(255)
  instagramFollowers     Int?            @map("instagram_followers")
  instagramLastPostAt    DateTime?       @map("instagram_last_post_at")
  instagramPostFrequency Int?            @map("instagram_post_frequency")
  facebookUrl            String?         @map("facebook_url")
  facebookFollowers      Int?            @map("facebook_followers")
  facebookLastPostAt     DateTime?       @map("facebook_last_post_at")
  facebookEngagementRate Float?          @map("facebook_engagement_rate")
  facebookAbandoned      Boolean?        @map("facebook_abandoned")
  uxScore                Int?            @map("ux_score")
  uxSignals              Json?           @map("ux_signals")
  rating             Decimal?        @db.Decimal(2, 1)
  reviewCount        Int?            @map("review_count")
  score              Int             @default(0)
  scoreBreakdown     Json?           @map("score_breakdown")
  temperature        LeadTemperature @default(COLD)
  opportunities      OpportunityType[]
  problems           String[]        @default([])
  suggestions        String[]        @default([])
  pitchContent       String?         @map("pitch_content")
  pitchTone          String?         @default("formal") @map("pitch_tone") @db.VarChar(50)
  contactedAt        DateTime?       @map("contacted_at")
  notes              String?
  enrichmentData      Json?           @map("enrichment_data")
  falsePositiveReason String?         @map("false_positive_reason")
  retentionUntil      DateTime?       @map("retention_until")
  // TASK-3 intake-review (CL-058/059/060): sinais estruturados dos enrichers dedicados
  isWhatsappChannel   Boolean?        @map("is_whatsapp_channel")
  hasEcommerce        Boolean?        @map("has_ecommerce")
  ecommercePlatform   String?         @map("ecommerce_platform") @db.VarChar(50)
  analyticsPixels     String[]        @default([]) @map("analytics_pixels")
  // TASK-4 intake-review (CL-063..CL-068): slugs de sinais de oportunidade disparados
  signals             String[]        @default([]) @map("signals")
  // TASK-5 intake-review: enriquecimento detalhado
  siteAudit           Json?           @map("site_audit")
  googleReviews       Json?           @map("google_reviews")
  serpRank            Json?           @map("serp_rank")
  adsStatus           Json?           @map("ads_status")
  techStack           String[]        @default([]) @map("tech_stack")
  placeId             String?         @map("place_id") @db.VarChar(255)
  facebookPageId      String?         @map("facebook_page_id") @db.VarChar(100)
  niche               String?         @db.VarChar(255)
  metadata            Json?
  createdAt           DateTime        @default(now()) @map("created_at")
  updatedAt           DateTime        @updatedAt @map("updated_at")

  user           UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  job            CollectionJob?   @relation(fields: [jobId], references: [id], onDelete: SetNull)
  rawLeadData    RawLeadData[]
  dataProvenance DataProvenance[]
  history        LeadHistory[]

  @@index([userId, score(sort: Desc)])
  @@index([userId, status])
  @@index([retentionUntil])
  @@index([userId, temperature])
  @@index([userId, city])
  @@index([userId, createdAt])
  @@map("leads")
}

// TASK-5 intake-review: historico de mudancas de campos do lead
model LeadHistory {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  field      String   @db.VarChar(100)
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  // TASK-9 (CL-225): snapshot completo pre-merge para permitir undo
  snapshot   Json?
  changedAt  DateTime @default(now()) @map("changed_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, changedAt(sort: Desc)])
  @@index([changedAt])
  @@map("lead_history")
}

model DataProvenance {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId         String     @map("lead_id") @db.Uuid
  field          String     @db.VarChar(100)
  source         DataSource
  sourceUrl      String?    @map("source_url")
  collectedAt    DateTime   @map("collected_at")
  confidence     Decimal    @default(1.00) @db.Decimal(3, 2)
  rawLeadDataId  String?    @map("raw_lead_data_id") @db.Uuid
  createdAt      DateTime   @default(now()) @map("created_at")

  lead        Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  rawLeadData RawLeadData? @relation(fields: [rawLeadDataId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@map("data_provenance")
}

model PitchTemplate {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  name       String   @db.VarChar(255)
  content    String
  tone       String   @default("formal") @db.VarChar(50)
  isFavorite Boolean  @default(false) @map("is_favorite")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("pitch_templates")
}

model ApiCredential {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider     String   @unique @db.VarChar(100)
  encryptedKey String   @map("encrypted_key")
  iv           String   @db.VarChar(32)
  isActive     Boolean  @default(true) @map("is_active")
  usageCount   Int      @default(0) @map("usage_count")
  usageResetAt DateTime? @map("usage_reset_at")
  expiresAt    DateTime? @map("expires_at")
  expiringNotifiedAt DateTime? @map("expiring_notified_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("api_credentials")
}

model ScoringRule {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  slug        String   @unique @db.VarChar(100)
  description String?
  weight      Int      @default(1)
  isActive    Boolean  @default(true) @map("is_active")
  condition   Json
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("scoring_rules")
}

model ScoringRuleHistory {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ruleId      String   @map("rule_id") @db.Uuid
  snapshot    Json
  changedBy   String?  @map("changed_by") @db.Uuid
  changeReason String? @map("change_reason") @db.VarChar(500)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([ruleId, createdAt])
  @@map("scoring_rule_history")
}

enum DuplicateStatus {
  PENDING
  MERGED
  KEEP_BOTH
  REJECTED
  UNDONE
}

model DuplicateCandidate {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String          @map("user_id") @db.Uuid
  primaryLeadId   String          @map("primary_lead_id") @db.Uuid
  candidateLeadId String          @map("candidate_lead_id") @db.Uuid
  similarity      Float
  reasons         String[]        @default([])
  // TASK-9 (CL-223..226): enum forte + campos de merge/undo + auditoria
  status          DuplicateStatus @default(PENDING)
  resolution      String?         @db.VarChar(20)
  resolvedBy      String?         @map("resolved_by") @db.Uuid
  resolvedAt      DateTime?       @map("resolved_at")
  mergedAt        DateTime?       @map("merged_at")
  mergedBy        String?         @map("merged_by") @db.Uuid
  undoneAt        DateTime?       @map("undone_at")
  undoneBy        String?         @map("undone_by") @db.Uuid
  mergeSnapshot   Json?           @map("merge_snapshot")
  createdAt       DateTime        @default(now()) @map("created_at")

  @@unique([primaryLeadId, candidateLeadId])
  @@index([userId, status])
  @@index([status, createdAt])
  @@map("duplicate_candidates")
}

model PitchVersion {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId      String   @map("lead_id") @db.Uuid
  content     String
  tone        String?  @db.VarChar(50)
  provider    String?  @db.VarChar(50)
  changedBy   String?  @map("changed_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([leadId, createdAt])
  @@map("pitch_versions")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    @db.VarChar(50)
  title     String    @db.VarChar(255)
  message   String
  data      Json?
  read      Boolean   @default(false)
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

/// Preferencias de notificacao por (usuario, evento).
/// `channels` eh um subconjunto de ['push','email','in-app'].
/// Origem: INTAKE-REVIEW TASK-9 / CL-133.
model NotificationPreference {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  event     String   @db.VarChar(50)
  channels  String[] @default([])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, event], name: "userId_event")
  @@index([userId])
  @@map("notification_preferences")
}

/// Web Push subscriptions (TASK-7 / CL-138). Um usuario pode ter N devices.
model PushSubscription {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?  @map("user_agent") @db.VarChar(500)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

model LoginAttempt {
  id        String   @id @default(uuid())
  email     String   @db.VarChar(255)
  ipAddress String   @map("ip_address") @db.VarChar(45)
  success   Boolean
  timestamp DateTime @default(now())

  @@index([email, timestamp])
  @@index([ipAddress, timestamp])
  @@map("login_attempts")
}

/// Anexos vinculados a Lead. Origem: INTAKE-REVIEW TASK-13 (CL-209).
model Attachment {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  leadId     String   @map("lead_id") @db.Uuid
  url        String
  filename   String   @db.VarChar(500)
  mimeType   String   @map("mime_type") @db.VarChar(100)
  size       Int
  uploadedBy String?  @map("uploaded_by") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@map("attachments")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  resource   String   @db.VarChar(100)
  resourceId String?  @map("resource_id") @db.Uuid
  metadata   Json?
  ipAddress  String?  @map("ip_address") @db.VarChar(50)
  createdAt  DateTime @default(now()) @map("created_at")

  user UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

// TASK-22 intake-review: historico de exports async para download posterior.
enum ExportHistoryStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
}

enum ExportFormat {
  CSV
  JSON
  VCF
}

model ExportHistory {
  id          String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  format      ExportFormat        @default(CSV)
  status      ExportHistoryStatus @default(PENDING)
  filters     Json?
  rowCount    Int?                @map("row_count")
  fileUrl     String?             @map("file_url")
  fileSize    Int?                @map("file_size")
  error       String?
  startedAt   DateTime?           @map("started_at")
  completedAt DateTime?           @map("completed_at")
  expiresAt   DateTime?           @map("expires_at")
  createdAt   DateTime            @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@map("export_history")
}

model Region {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  uf        String   @unique @db.VarChar(2)
  name      String   @db.VarChar(100)
  capital   String   @db.VarChar(100)
  cities    String[] @default([])
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([archived])
  @@map("regions")
}

model Niche {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String   @unique @db.VarChar(100)
  label     String   @db.VarChar(255)
  keywords  String[] @default([])
  archived  Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([archived])
  @@map("niches")
}

// TASK-2 intake-review (CL-310, CL-403, CL-495): waitlist publica da landing.
model WaitlistEntry {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique @db.VarChar(255)
  name          String?        @db.VarChar(255)
  businessType  BusinessType?  @map("business_type")
  status        WaitlistStatus @default(PENDING)
  invitedAt     DateTime?      @map("invited_at")
  invitedById   String?        @map("invited_by_id") @db.Uuid
  ip            String?        @db.VarChar(45)
  userAgent     String?        @map("user_agent") @db.VarChar(500)
  consentLgpd   Boolean        @default(false) @map("consent_lgpd")
  consentId     String?        @map("consent_id") @db.Uuid
  retentionUntil DateTime?     @map("retention_until")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([retentionUntil])
  @@map("waitlist_entries")
}

// TASK-2 intake-review (CL-311, CL-403, CL-494): mensagens de contato da landing.
model ContactMessage {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String        @db.VarChar(255)
  name         String        @db.VarChar(255)
  subject      String        @db.VarChar(255)
  message      String        @db.Text
  status       ContactStatus @default(NEW)
  repliedAt    DateTime?     @map("replied_at")
  repliedById  String?       @map("replied_by_id") @db.Uuid
  replyContent String?       @map("reply_content") @db.Text
  ip           String?       @db.VarChar(45)
  userAgent    String?       @map("user_agent") @db.VarChar(500)
  consentLgpd  Boolean       @default(false) @map("consent_lgpd")
  consentId    String?       @map("consent_id") @db.Uuid
  retentionUntil DateTime?   @map("retention_until")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@index([status, createdAt])
  @@index([email])
  @@index([retentionUntil])
  @@map("contact_messages")
}

// TASK-3 intake-review (CL-312): registro de consent LGPD da landing.
model LandingConsent {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ipHash            String   @map("ip_hash") @db.VarChar(64)
  userAgent         String   @map("user_agent") @db.VarChar(500)
  version           String   @db.VarChar(20)

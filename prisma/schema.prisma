  waitlistEntryId   String?  @map("waitlist_entry_id") @db.Uuid
  contactMessageId  String?  @map("contact_message_id") @db.Uuid
  acceptedAt        DateTime @default(now()) @map("accepted_at")

  @@index([ipHash])
  @@index([acceptedAt])
  @@map("landing_consents")
}

enum UsageKind {
  API
  LLM
}

model ApiUsageLog {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  provider      String    @db.VarChar(100)
  callType      String    @map("call_type") @db.VarChar(50)
  creditCost    Int       @default(1) @map("credit_cost")
  userId        String?   @map("user_id") @db.Uuid
  jobId         String?   @map("job_id") @db.Uuid
  leadId        String?   @map("lead_id") @db.Uuid
  metadata      Json?
  timestamp     DateTime  @default(now())
  // TASK-10 intake-review (CL-216/CL-243): LLM cost tracking (ADR-0006)
  kind          UsageKind @default(API)
  model         String?   @db.VarChar(100)
  operation     String?   @db.VarChar(100)
  inputTokens   Int?      @map("input_tokens")
  outputTokens  Int?      @map("output_tokens")
  costUsd       Decimal?  @db.Decimal(10, 6) @map("cost_usd")
  latencyMs     Int?      @map("latency_ms")
  correlationId String?   @map("correlation_id") @db.VarChar(100)

  @@index([provider, timestamp])
  @@index([provider, callType, timestamp])
  @@index([userId, timestamp])
  @@index([kind, timestamp])
  @@map("api_usage_logs")
}

// TASK-13 intake-review: configuracao de sistema (alertas, thresholds, limites)
// e historico de alertas enviados para dedupe diario.
model SystemConfig {
  key       String   @id @db.VarChar(120)
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by") @db.Uuid

  @@map("system_config")
}

model SentAlert {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rule      String   @db.VarChar(80)
  dayKey    String   @map("day_key") @db.VarChar(20)
  payload   Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([rule, dayKey])
  @@index([createdAt])
  @@map("sent_alerts")
}

// TASK-18/ST005 intake-review (CL-283): notas de contato estruturadas.
// Mantemos `Lead.notes` livre para compat; este model registra interacoes
// canal-resultado com timestamp e autor.
enum ContactChannel {

// TASK-16 intake-review (CL-267, CL-490): tags customizadas por operador
// + visoes de filtros salvas. Per-user (nao compartilhadas).
model LeadTag {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
